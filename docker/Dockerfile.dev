FROM python:3.11-slim

# Security: run as non-root
RUN groupadd -r ares && useradd -r -g ares ares

# Install OS deps for weasyprint
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpango-1.0-0 libpangoft2-1.0-0 libgdk-pixbuf2.0-0 \
    libffi-dev libcairo2 libpq-dev curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python deps first (layer caching)
COPY pyproject.toml .
RUN pip install --no-cache-dir -e ".[dev]"

# Copy source
COPY ares/ ./ares/

# Create runtime dirs
RUN mkdir -p /home/ares/.ares/campaigns /home/ares/.ares/reports logs \
    && chown -R ares:ares /app /home/ares

USER ares

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

CMD ["python", "-m", "uvicorn", "ares.api.server:app", "--host", "0.0.0.0", "--port", "8080", "--reload"]
